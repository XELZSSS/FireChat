# Copy this file to `.env` or `.env.local` and fill only the values you need.
# Provider and search defaults are read by the renderer.
# Electron main-process keys in this file are also loaded at startup.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_BASE_URL=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Poe
POE_API_KEY=
POE_MODEL=Claude-Sonnet-4.6
POE_BASE_URL=https://api.poe.com/v1

# Google / Gemini
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash
GOOGLE_GENERATIVE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Together AI
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
TOGETHER_BASE_URL=https://api.together.xyz/v1

# Fireworks AI
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Cerebras
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# Cohere
COHERE_API_KEY=
COHERE_MODEL=command-a-03-2025
COHERE_BASE_URL=https://api.cohere.com/v2

# SambaNova
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1

# Mistral AI
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# LongCat
LONGCAT_API_KEY=
LONGCAT_MODEL=LongCat-Flash-Chat
LONGCAT_BASE_URL=https://api.longcat.chat/openai/v1

# ModelScope
MODELSCOPE_API_KEY=
MODELSCOPE_MODEL=Qwen/Qwen3-8B
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# Modal
# Use custom headers such as Modal-Key and Modal-Secret in Settings when your endpoint is proxy-protected.
MODAL_MODEL=google/gemma-4-26b-a4b-it
MODAL_BASE_URL=

# OpenAdapter
OPENADAPTER_API_KEY=
OPENADAPTER_MODEL=DeepSeek-V3
OPENADAPTER_BASE_URL=https://api.openadapter.in/v1

# OpenCode
OPENCODE_API_KEY=
OPENCODE_MODEL=gpt-5.5
OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# OpenAI-Compatible
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4.1-mini
OPENAI_COMPATIBLE_BASE_URL=

# xAI
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast-reasoning
XAI_BASE_URL=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=

# GLM
GLM_API_KEY=
GLM_MODEL=glm-5
GLM_BASE_URL=

# MiniMax
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_BASE_URL=

# Kimi / Moonshot
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_BASE_URL=

# Tavily search
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5

# Exa search
EXA_API_KEY=
EXA_MAX_RESULTS=5

# Firecrawl search
FIRECRAWL_API_KEY=
FIRECRAWL_TOPIC=general
FIRECRAWL_MAX_RESULTS=5
FIRECRAWL_LOCATION=
FIRECRAWL_COUNTRY=
FIRECRAWL_SCRAPE_CONTENT=false

# SearXNG search
SEARXNG_BASE_URL=
SEARXNG_LANGUAGE=all
SEARXNG_TIME_RANGE=
SEARXNG_SAFE_SEARCH=1

# App
TOOL_CALL_MAX_ROUNDS=5
# MAX_TOOL_CALL_ROUNDS=5

# Dev / OAuth helpers
# OAUTH_CALLBACK_PORT=1457
# FireChat_ALLOW_SECOND_INSTANCE=1
