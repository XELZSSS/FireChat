{
  "name": "firechat",
  "description": "FireChat desktop chat client",
  "author": "FireChat",
  "license": "GPL-3.0-only",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "main": "apps/desktop/main/main.cjs",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite",
    "electron:dev": "concurrently -k -n dev,electron -c cyan,magenta \"npm run dev\" \"wait-on http://localhost:3000 && node apps/desktop/main/scripts/launch-electron.cjs . http://localhost:3000\"",
    "proxy:dev": "node apps/desktop/main/scripts/start-local-api-proxy.cjs",
    "build": "vite build",
    "electron:build:win": "node apps/desktop/main/scripts/build-electron-win.cjs",
    "preview": "vite preview",
    "check": "npm run lint && npm run typecheck",
    "check:fix": "npm run lint:fix && npm run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "audit": "set \"npm_config_registry=https://registry.npmjs.org/\" && npm audit",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^1.0.23",
    "@ai-sdk/amazon-bedrock": "^4.0.107",
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/azure": "^3.0.65",
    "@ai-sdk/black-forest-labs": "^1.0.33",
    "@ai-sdk/cerebras": "^2.0.51",
    "@ai-sdk/cohere": "^3.0.36",
    "@ai-sdk/deepinfra": "^2.0.51",
    "@ai-sdk/fal": "^2.0.34",
    "@ai-sdk/fireworks": "^2.0.52",
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/google-vertex": "^4.0.131",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/huggingface": "^1.0.49",
    "@ai-sdk/luma": "^2.0.33",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/moonshotai": "^2.0.22",
    "@ai-sdk/open-responses": "^1.0.16",
    "@ai-sdk/openai": "^3.0.64",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@ai-sdk/perplexity": "^3.0.33",
    "@ai-sdk/prodia": "^1.0.31",
    "@ai-sdk/replicate": "^2.0.33",
    "@ai-sdk/togetherai": "^2.0.52",
    "@ai-sdk/vercel": "^2.0.49",
    "@ai-sdk/xai": "^3.0.91",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "ai": "^6.0.185",
    "fflate": "^0.8.3",
    "http-proxy": "^1.18.1",
    "longcat-ai-sdk-provider": "^0.0.5",
    "lucide-react": "^1.16.0",
    "luma-mcp": "^1.3.8",
    "mammoth": "^1.12.0",
    "mcp-searxng": "^1.0.3",
    "officeparser": "^7.0.3",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-syntax-highlighter": "^16.1.1",
    "sambanova-ai-provider": "^1.2.2",
    "tailwind-merge": "^3.6.0",
    "undici": "^8.3.0",
    "uuid": "^14.0.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "zhipu-ai-provider": "^0.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.0",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "26.8.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "flatted": "3.4.2",
    "follow-redirects": "^1.16.0",
    "gaxios": "7.1.4",
    "google-auth-library": "10.6.2",
    "node-gyp": "^12.2.0",
    "tar": "^7.5.13",
    "undici": "^8.3.0",
    "yauzl": "^3.3.0"
  },
  "build": {
    "appId": "com.firechat.app",
    "productName": "FireChat",
    "directories": {
      "output": "release",
      "buildResources": "."
    },
    "files": [
      "dist/**",
      "apps/desktop/main/**",
      "apps/shared/**",
      "packages/contracts/**",
      "packages/desktop-bridge/**",
      "packages/data/**",
      "assets/icons/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "apps/shared",
        "to": "shared"
      }
    ],
    "win": {
      "executableName": "FireChat",
      "icon": "assets/icons/app.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "assets/icons/app.ico",
      "uninstallerIcon": "assets/icons/app.ico",
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "XELZSSS",
        "repo": "FireChat"
      }
    ]
  }
}
